{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/agent/thread/error.v1.json",
  "title": "Agent Thread Error Event",
  "description": "Agent interaction failed",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../_common/base_event.v1.json"
    }
  ],
  "properties": {
    "event_type": {
      "type": "string",
      "const": "agent.thread.error",
      "description": "Event type discriminator"
    },
    "payload": {
      "type": "object",
      "properties": {
        "provider": {
          "type": "string"
        },
        "model": {
          "type": [
            "string",
            "null"
          ]
        },
        "error_message": {
          "type": "string"
        },
        "error_code": {
          "type": [
            "string",
            "null"
          ]
        },
        "is_retryable": {
          "type": "boolean"
        },
        "retry_count": {
          "type": "integer"
        }
      },
      "required": [
        "provider",
        "error_message"
      ]
    }
  },
  "required": [
    "event_type",
    "payload"
  ]
}