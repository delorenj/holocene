{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/session/thread/error.v1.json",
  "title": "Session Thread Error Event",
  "description": "Error occurred during session",
  "type": "object",
  "allOf": [
    {
      "$ref": "../_common/base_event.v1.json"
    }
  ],
  "properties": {
    "event_type": {
      "type": "string",
      "const": "session.thread.error",
      "description": "Event type discriminator"
    },
    "payload": {
      "type": "object",
      "properties": {
        "session_id": {
          "type": "string"
        },
        "thread_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "error_type": {
          "type": "string"
        },
        "error_message": {
          "type": "string"
        },
        "stack_trace": {
          "type": [
            "string",
            "null"
          ]
        },
        "tool_name": {
          "type": [
            "string",
            "null"
          ]
        },
        "recoverable": {
          "type": "boolean"
        },
        "turn_number": {
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "required": [
        "session_id",
        "error_type",
        "error_message"
      ]
    }
  },
  "required": [
    "event_type",
    "payload"
  ]
}