{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/session/thread/message.v1.json",
  "title": "Session Thread Message Event",
  "description": "User message or assistant response in session",
  "type": "object",
  "allOf": [
    {
      "$ref": "../_common/base_event.v1.json"
    }
  ],
  "properties": {
    "event_type": {
      "type": "string",
      "const": "session.thread.message",
      "description": "Event type discriminator"
    },
    "payload": {
      "type": "object",
      "properties": {
        "session_id": {
          "type": "string"
        },
        "thread_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "role": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "turn_number": {
          "type": "integer"
        },
        "tokens": {
          "type": [
            "integer",
            "null"
          ]
        },
        "model": {
          "type": [
            "string",
            "null"
          ]
        },
        "thinking_included": {
          "type": "boolean"
        },
        "tool_calls": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "session_id",
        "role",
        "content",
        "turn_number"
      ]
    }
  },
  "required": [
    "event_type",
    "payload"
  ]
}